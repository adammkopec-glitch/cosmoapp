// filepath: apps/server/prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  EMPLOYEE
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum LoyaltyTier {
  BRONZE   // 0-499 pts
  SILVER   // 500-1499 pts
  GOLD     // 1500+ pts
}

enum TransactionType {
  EARN
  REDEEM
  MANUAL_ADJUST
}

enum DiscountType {
  PERCENTAGE
  AMOUNT
  OTHER
}

enum CouponStatus {
  ACTIVE
  USED
}

enum RescheduleStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TreatmentSeriesStatus {
  ACTIVE
  COMPLETED
}

enum TreatmentSeriesNotificationKind {
  BEFORE_DUE
  DUE
  OVERDUE
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  passwordHash   String
  name           String
  phone          String?
  role           Role      @default(USER)
  avatarPath     String?
  loyaltyPoints  Int       @default(0)
  loyaltyTier    LoyaltyTier @default(BRONZE)
  resetToken     String?
  resetTokenExp  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  termsAcceptedAt  DateTime?
  marketingConsent Boolean   @default(false)
  photoConsent     Boolean   @default(false)
  onboardingCompleted Boolean @default(false)

  cardAllergies   String?
  cardConditions  String?
  cardPreferences String?
  cardStaffNotes  String?

  ambassadorCode      String?  @unique
  referredById        String?
  referredBy          User?    @relation("Referrals", fields: [referredById], references: [id])
  referrals           User[]   @relation("Referrals")
  referralCount       Int      @default(0)

  appointments        Appointment[]
  loyaltyTransactions LoyaltyTransaction[]
  coupons             UserCoupon[]
  sentMessages        ChatMessage[]  @relation("SentMessages")
  receivedMessages    ChatMessage[]  @relation("ReceivedMessages")
  chatRoom            ChatRoom?      @relation("UserChatRoom")
  adminChatRooms      ChatRoom[]     @relation("AdminChatRooms")
  blogPosts            BlogPost[]
  blogComments         BlogComment[]         @relation("BlogCommentAuthor")
  blogCommentReactions BlogCommentReaction[] @relation("BlogCommentReactions")
  employee            Employee?
  lockedDiscountCodes DiscountCode[]      @relation("LockedDiscountCodes")
  discountCodeUsages  DiscountCodeUsage[] @relation("DiscountCodeUsages")
  pushSubscriptions   PushSubscription[]
  reviews             Review[]
  achievements        UserAchievement[]
  serviceReminders    ServiceReminder[]
  treatmentSeries     TreatmentSeries[]
  notifications       Notification[]
  appointmentRecommendations   AppointmentRecommendation[]
  addedRecommendations         AppointmentRecommendation[] @relation("RecommendationAddedBy")
  skinJournalEntries           SkinJournalEntry[]
  journalEntriesAuthored       SkinJournalEntry[]  @relation("JournalEntryAuthor")
  journalComments              SkinJournalComment[]
  blogPostLikes                BlogPostLike[]
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

model Service {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  description     String
  price           Decimal  @db.Decimal(10,2)
  durationMinutes Int
  category        String
  imagePath       String?
  isActive                Boolean  @default(true)
  detailedContent         String?
  recommendedIntervalDays Int?
  isMultiVisit            Boolean  @default(false)
  seriesIntervalsDays     Int[]    @default([])
  routineFirst48h      String?
  routineFollowingDays String?
  routineProducts      String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  appointments    Appointment[]
  metamorphoses   Metamorphosis[]
  loyaltyRewards  LoyaltyReward[] @relation("RewardServices")
  employees       Employee[]      @relation("ServiceEmployees")
  quizResults     QuizResult[]
  quizSuggestions QuizResultSuggestion[]
  reviews         Review[]
  treatmentSeries TreatmentSeries[]
}

model BlogPost {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  content         String   // TipTap JSON serialized
  excerpt         String
  coverImage      String?
  isPublished     Boolean  @default(false)
  views           Int      @default(0)
  readingTime     Int?
  metaTitle       String?
  metaDescription String?
  authorId        String
  author          User     @relation(fields: [authorId], references: [id])
  tags            Tag[]    @relation("PostTags")
  comments        BlogComment[]
  likes           BlogPostLike[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model BlogPostLike {
  id        String   @id @default(cuid())
  postId    String
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([postId])
}

model Tag {
  id    String     @id @default(cuid())
  name  String     @unique
  slug  String     @unique
  posts BlogPost[] @relation("PostTags")
}

model BlogComment {
  id        String   @id @default(cuid())
  postId    String
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation("BlogCommentAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  parentId  String?
  parent    BlogComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  replies   BlogComment[] @relation("CommentReplies")
  content   String
  imagePath String?
  isHidden  Boolean  @default(false)
  isSpam    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reactions BlogCommentReaction[]

  @@index([postId])
  @@index([parentId])
}

model BlogCommentReaction {
  id        String      @id @default(cuid())
  commentId String
  comment   BlogComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation("BlogCommentReactions", fields: [userId], references: [id], onDelete: Cascade)
  emoji     String
  createdAt DateTime    @default(now())

  @@unique([commentId, userId])
  @@index([commentId])
}

model Metamorphosis {
  id          String   @id @default(cuid())
  title       String
  description String?
  beforeImage String
  afterImage  String
  serviceId   String?
  service     Service? @relation(fields: [serviceId], references: [id])
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model LoyaltyReward {
  id          String   @id @default(cuid())
  name        String
  description String
  pointsCost  Int
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  requiredTier        LoyaltyTier?
  isForAllServices    Boolean @default(true)
  applicableServices  Service[] @relation("RewardServices")

  discountType        DiscountType @default(AMOUNT)
  discountValue       Decimal?     @db.Decimal(10,2)

  redemptions LoyaltyTransaction[]
  userCoupons UserCoupon[]
}

model LoyaltyTransaction {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id])
  points      Int
  type        TransactionType
  description String
  rewardId    String?
  reward      LoyaltyReward?  @relation(fields: [rewardId], references: [id])
  createdAt   DateTime        @default(now())
}

model UserCoupon {
  id            String        @id @default(cuid())
  code          String?       @unique
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  rewardId      String
  reward        LoyaltyReward @relation(fields: [rewardId], references: [id])
  status        CouponStatus  @default(ACTIVE)
  activatedAt   DateTime      @default(now())
  usedAt        DateTime?
  appointmentId String?       @unique
  appointment   Appointment?  @relation(fields: [appointmentId], references: [id])
}

model Employee {
  id          String   @id @default(cuid())
  name        String
  bio         String?
  avatarPath  String?
  specialties String[]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  userId       String?  @unique
  user         User?    @relation(fields: [userId], references: [id])

  appointments   Appointment[]
  workDays       EmployeeWorkDay[]
  weeklySchedule EmployeeWeeklySchedule[]
  services       Service[]               @relation("ServiceEmployees")
}

model EmployeeWorkDay {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date       DateTime // stored as midnight UTC for that day
  timeBlocks Json?    // [{ start: "09:00", end: "13:00" }]
  isWorking  Boolean  @default(true)
  note       String?
  createdAt  DateTime @default(now())

  @@unique([employeeId, date])
}

model EmployeeWeeklySchedule {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  dayOfWeek  Int      // 0=Mon, 1=Tue, 2=Wed, 3=Thu, 4=Fri, 5=Sat, 6=Sun
  isWorking  Boolean  @default(true)
  timeBlocks Json     // [{ start: "09:00", end: "13:00" }]
  updatedAt  DateTime @updatedAt

  @@unique([employeeId, dayOfWeek])
}

model Appointment {
  id                 String            @id @default(cuid())
  userId             String
  user               User              @relation(fields: [userId], references: [id])
  serviceId          String
  service            Service           @relation(fields: [serviceId], references: [id])
  employeeId         String?
  employee           Employee?         @relation(fields: [employeeId], references: [id])
  date               DateTime
  status             AppointmentStatus @default(PENDING)
  notes              String?
  allergies          String?
  problemDescription String?
  photoPath          String?
  staffNote          String?
  completedAt        DateTime?
  treatmentSeriesId  String?
  treatmentSeries    TreatmentSeries?    @relation(fields: [treatmentSeriesId], references: [id], onDelete: SetNull)
  treatmentSeriesStep Int?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  coupon             UserCoupon?
  discountCodeUsage  DiscountCodeUsage?
  review             Review?
  recommendations    AppointmentRecommendation[]
  homecareRoutine    HomecareRoutine?

  rescheduleDate     DateTime?
  rescheduleStatus   RescheduleStatus?

  @@index([treatmentSeriesId])
}

model DiscountCode {
  id             String              @id @default(cuid())
  code           String              @unique
  discountType   DiscountType
  discountValue  Decimal             @db.Decimal(10, 2)
  isActive       Boolean             @default(true)
  lockedToUserId String?
  lockedToUser   User?               @relation("LockedDiscountCodes", fields: [lockedToUserId], references: [id])
  usages         DiscountCodeUsage[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
}

model DiscountCodeUsage {
  id             String       @id @default(cuid())
  discountCodeId String
  discountCode   DiscountCode @relation(fields: [discountCodeId], references: [id])
  userId         String
  user           User         @relation("DiscountCodeUsages", fields: [userId], references: [id])
  appointmentId  String?      @unique
  appointment    Appointment? @relation(fields: [appointmentId], references: [id])
  usedAt         DateTime     @default(now())

  @@unique([discountCodeId, userId])
}

model AmbassadorConfig {
  id            String       @id @default(cuid())
  discountType  DiscountType @default(PERCENTAGE)
  discountValue Decimal      @db.Decimal(10, 2) @default(10)
  updatedAt     DateTime     @updatedAt
}

model SalonTerms {
  id        String   @id @default(cuid())
  content   String
  version   String   @default("1.0")
  updatedAt DateTime @updatedAt
}

model HeroSlide {
  id           String   @id @default(cuid())
  imagePath    String
  title        String?
  heading      String?
  subtitle     String?
  textPosition String?  @default("middle-center")
  fontStyle    String?  @default("heading")
  buttons      Json?
  order        Int      @default(0)
  isMain       Boolean  @default(false)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
}

model AboutPage {
  id                String   @id @default(cuid())
  salonTagline      String   @default("")
  salonDescription  String   @default("")
  salonCoverImage   String?
  ownerName         String   @default("Wiktoria Ćwik")
  ownerTitle        String   @default("Właścicielka & Kosmetolożka")
  ownerBio          String   @default("")
  ownerPhoto        String?
  featuresTitle     String   @default("Dlaczego warto wybrać Cosmo?")
  features          Json     @default("[]")
  appDescription    String   @default("")
  updatedAt         DateTime @updatedAt
}

model ConsultationLead {
  id             String    @id @default(cuid())
  name           String
  email          String
  phone          String
  consentContact Boolean   @default(false)
  consentData    Boolean   @default(false)
  contacted      Boolean   @default(false)
  archived       Boolean   @default(false)
  contactedAt    DateTime?
  notes          String?
  createdAt      DateTime  @default(now())
}

model ChatRoom {
  id            String    @id @default(cuid())
  userId        String    @unique
  user          User      @relation("UserChatRoom", fields: [userId], references: [id])
  adminId       String?
  admin         User?     @relation("AdminChatRooms", fields: [adminId], references: [id])
  lastMessageAt DateTime  @default(now())
  userUnread    Int       @default(0)
  adminUnread   Int       @default(0)
  messages      ChatMessage[]
  createdAt     DateTime  @default(now())
}

model ChatMessage {
  id             String    @id @default(cuid())
  roomId         String
  room           ChatRoom  @relation(fields: [roomId], references: [id])
  senderId       String
  sender         User      @relation("SentMessages", fields: [senderId], references: [id])
  receiverId     String
  receiver       User      @relation("ReceivedMessages", fields: [receiverId], references: [id])
  content        String
  attachmentUrl  String?
  attachmentType String?   // "image" | "video"
  readAt         DateTime? // null = unread; replaces isRead Boolean
  createdAt      DateTime  @default(now())
}

enum BodyPart {
  STOPY
  TWARZ
  DLONIE
  DEKOLT
}

enum QuizNodeType {
  START
  QUESTION
  RESULT
}

model Quiz {
  id        String     @id @default(cuid())
  title     String
  bodyPart  BodyPart
  isActive  Boolean    @default(true)
  nodes     QuizNode[]
  edges     QuizEdge[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model QuizNode {
  id          String       @id @default(cuid())
  quizId      String
  quiz        Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  type        QuizNodeType
  positionX   Float
  positionY   Float
  data        Json
  result      QuizResult?
  sourceEdges QuizEdge[]   @relation("EdgeSource")
  targetEdges QuizEdge[]   @relation("EdgeTarget")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([quizId])
}

model QuizEdge {
  id           String   @id @default(cuid())
  quizId       String
  quiz         Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  sourceNodeId String
  sourceNode   QuizNode @relation("EdgeSource", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  targetNodeId String
  targetNode   QuizNode @relation("EdgeTarget", fields: [targetNodeId], references: [id], onDelete: Cascade)
  sourceHandle String
  createdAt    DateTime @default(now())

  @@index([quizId])
  @@index([sourceNodeId])
  @@index([targetNodeId])
}

model QuizResult {
  id            String                 @id @default(cuid())
  nodeId        String                 @unique
  node          QuizNode               @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  mainServiceId String?
  mainService   Service?               @relation(fields: [mainServiceId], references: [id])
  suggestions   QuizResultSuggestion[]
  updatedAt     DateTime               @updatedAt
}

model QuizResultSuggestion {
  id        String     @id @default(cuid())
  resultId  String
  result    QuizResult @relation(fields: [resultId], references: [id], onDelete: Cascade)
  serviceId String
  service   Service    @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  order     Int
  updatedAt DateTime   @updatedAt

  @@unique([resultId, order])
}

// ============ Trendsetter Pack ============

model Review {
  id            String      @id @default(cuid())
  rating        Int         // 1-5
  comment       String?
  isVisible     Boolean     @default(true)
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  appointmentId String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id])
  serviceId     String
  service       Service     @relation(fields: [serviceId], references: [id])
  createdAt     DateTime    @default(now())

  @@index([serviceId])
  @@index([userId])
}

model Achievement {
  id          String            @id @default(cuid())
  key         String            @unique
  name        String
  description String
  icon        String
  pointsBonus Int               @default(0)
  condition   Json              // { type: "VISIT_COUNT", value: 10 }
  sortOrder   Int               @default(0)
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  users       UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id])
  earnedAt      DateTime    @default(now())

  @@unique([userId, achievementId])
}

model TreatmentSeries {
  id                     String                           @id @default(cuid())
  userId                 String
  user                   User                             @relation(fields: [userId], references: [id], onDelete: Cascade)
  serviceId              String
  service                Service                          @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  intervalsDays          Int[]
  totalVisits            Int
  completedVisits        Int                              @default(0)
  nextStep               Int?
  nextDueDate            DateTime?
  lastCompletedAt        DateTime?
  status                 TreatmentSeriesStatus            @default(ACTIVE)
  startedFromAppointmentId String?
  completedAt            DateTime?
  createdAt              DateTime                         @default(now())
  updatedAt              DateTime                         @updatedAt

  appointments           Appointment[]
  notifications          TreatmentSeriesNotification[]

  @@index([userId, status])
  @@index([serviceId, status])
}

model TreatmentSeriesNotification {
  id                String                          @id @default(cuid())
  treatmentSeriesId String
  treatmentSeries   TreatmentSeries                 @relation(fields: [treatmentSeriesId], references: [id], onDelete: Cascade)
  kind              TreatmentSeriesNotificationKind
  bucketKey         String
  scheduledFor      DateTime
  sentAt            DateTime                        @default(now())

  @@unique([treatmentSeriesId, kind, bucketKey])
  @@index([scheduledFor])
}

model ServiceReminder {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  serviceId String
  sentAt    DateTime @default(now())

  @@index([userId, serviceId])
}

enum NotificationType {
  APPOINTMENT_CONFIRMED
  APPOINTMENT_CANCELLED
  APPOINTMENT_RESCHEDULED
  LOYALTY_POINTS
  LOYALTY_TIER_UP
  SERIES_REMINDER
  GENERIC
  CHAT_MESSAGE
  ACHIEVEMENT_UNLOCKED
  JOURNAL_COMMENT
  RECOMMENDATION_ADDED
  NEW_APPOINTMENT
  NEW_CONSULTATION
  NEW_REVIEW
  BROADCAST
  BLOG_COMMENT_REPLY
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType @default(GENERIC)
  title     String
  body      String
  url       String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

model Product {
  id          String   @id @default(cuid())
  name        String
  brand       String?
  description String?
  price       Float
  stock       Int      @default(0)
  imagePath   String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  recommendations AppointmentRecommendation[]
}

model AppointmentRecommendation {
  id            String      @id @default(cuid())
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  addedById     String
  addedBy       User        @relation("RecommendationAddedBy", fields: [addedById], references: [id])

  productId     String?
  product       Product?    @relation(fields: [productId], references: [id], onDelete: SetNull)

  name          String
  comment       String?

  pickedUp      Boolean  @default(false)
  pickedUpAt    DateTime?

  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([appointmentId])
}

model SkinJournalEntry {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  authorId            String?
  author              User?    @relation("JournalEntryAuthor", fields: [authorId], references: [id])
  isAdminEntry        Boolean  @default(false)
  date                DateTime @default(now())
  mood                Int?
  notes               String?
  photoPath           String?
  linkedAppointmentId String?
  tags                String[] @default([])
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  comments            SkinJournalComment[]

  @@index([userId, date])
}

model SkinJournalComment {
  id        String           @id @default(cuid())
  entryId   String
  entry     SkinJournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  authorId  String
  author    User             @relation(fields: [authorId], references: [id])
  content   String
  readAt    DateTime?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([entryId])
  @@index([authorId])
}

model HomecareRoutine {
  id            String      @id @default(cuid())
  appointmentId String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  first48h      String
  followingDays String
  products      String
  sentAt        DateTime?
  viewedAt      DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}
